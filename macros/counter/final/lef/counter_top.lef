    END
  END reset_n_i
  OBS
      LAYER GatPoly ;
        RECT 5.760 14.970 193.920 181.590 ;
      LAYER Metal1 ;
        RECT 5.760 14.900 193.920 181.660 ;
      LAYER Metal2 ;
