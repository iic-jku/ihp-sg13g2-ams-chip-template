    END
  END counter_value_o[4]
  PIN counter_value_o[5]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.708600 ;
    PORT
      LAYER Metal3 ;
        RECT 199.600 67.420 200.000 67.820 ;
    END
  END counter_value_o[5]
  PIN counter_value_o[6]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.708600 ;
    PORT
      LAYER Metal3 ;
        RECT 199.600 79.180 200.000 79.580 ;
    END
  END counter_value_o[6]
  PIN counter_value_o[7]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.708600 ;
    PORT
      LAYER Metal3 ;
        RECT 199.600 90.940 200.000 91.340 ;
    END
  END counter_value_o[7]
  PIN enable_i
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.180700 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 17.020 0.400 17.420 ;
    END
  END enable_i
  PIN reset_n_i
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.180700 ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 49.780 0.400 50.180 ;
    END
  END reset_n_i
  OBS
      LAYER GatPoly ;
        RECT 5.760 14.970 193.920 83.310 ;
      LAYER Metal1 ;
        RECT 5.760 14.900 193.920 83.380 ;
      LAYER Metal2 ;
        RECT 6.135 8.675 193.545 91.285 ;
      LAYER Metal3 ;
        RECT 0.400 90.730 199.390 91.240 ;
        RECT 0.400 83.150 199.600 90.730 ;
        RECT 0.610 82.330 199.600 83.150 ;
        RECT 0.400 79.790 199.600 82.330 ;
        RECT 0.400 78.970 199.390 79.790 ;
        RECT 0.400 68.030 199.600 78.970 ;
        RECT 0.400 67.210 199.390 68.030 ;
