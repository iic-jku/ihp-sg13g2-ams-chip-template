VERSION 5.7 ;
  NOWIREEXTENSIONATPIN ON ;
  DIVIDERCHAR "/" ;
  BUSBITCHARS "[]" ;
MACRO counter_top
  CLASS BLOCK ;
  FOREIGN counter_top ;
  ORIGIN 0.000 0.000 ;
  SIZE 200.000 BY 200.000 ;
  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER TopMetal1 ;
        RECT 18.260 14.900 20.460 181.660 ;
    END
    PORT
      LAYER TopMetal1 ;
        RECT 93.860 14.900 96.060 181.660 ;
    END
    PORT
      LAYER TopMetal1 ;
        RECT 169.460 14.900 171.660 181.660 ;
    END
