#
# This file acts as a catalogue of all pinout bindings you may want,
# so that you can copy-paste them to build your own .pcf file out
# of it. It is also possible, of course, to use custom names.
#
# See https://pico-ice.tinyvision.ai/pinout.html for the position
# of the pins on the board.

# Reference for PMOD names:
# https://digilent.com/reference/pmod/start

# Signals used by the default firmware
set_io -nowarn clock_i          35

# ice push_button. active low!
set_io -nowarn reset_n_i        10
set_io -nowarn enable_i         15
# set_io -nowarn FREE           37
# set_io -nowarn FREE           14
# set_io -nowarn FREE           17
# set_io -nowarn FREE           19
# set_io -nowarn FREE           18
# set_io -nowarn FREE           25
# set_io -nowarn FREE           27
# set_io -nowarn FREE           20

# gpio inputs on top left pmod
# set_io gpio_in[0] 31
# set_io gpio_in[1] 34
# set_io gpio_in[2] 38
# set_io gpio_in[3] 43
# set_io gpio_in[4] 28
# set_io gpio_in[5] 32
# set_io gpio_in[6] 36
# set_io gpio_in[7] 42

# gpio outputs on bottom left pmod
set_io counter_value_o[0] 45
set_io counter_value_o[1] 47
set_io counter_value_o[2] 2
set_io counter_value_o[3] 4
set_io counter_value_o[4] 44
set_io counter_value_o[5] 46
set_io counter_value_o[6] 48
set_io counter_value_o[7] 3
