/RawData currentfile /ASCII85Decode filter def
/Data RawData << >> /DCTDecode filter def
1580.000000 1020.000000 translate
800.000000 400.000000 scale
/DeviceRGB setcolorspace
{ << /ImageType 1
     /Width 2401
     /Height 1201
     /ImageMatrix [2401 0 0 1201 0 0]
     /DataSource Data
     /BitsPerComponent 8
     /Decode [0 1 0 1 0 1]
  >> image
  Data closefile
  RawData flushfile
  restore
} exec
